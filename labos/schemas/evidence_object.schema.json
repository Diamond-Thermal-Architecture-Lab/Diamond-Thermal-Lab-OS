{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labos/evidence_object.schema.json",
  "title": "Diamond Thermal Lab OS Evidence Object",
  "type": "object",
  "required": ["evidence_format_version", "evidence_id", "case_id", "title", "evidence_type", "status", "evidence_level", "source", "method_summary", "applicability", "uncertainty_summary", "supports_claim_ids", "contradicts_claim_ids", "measurement_reference_ids", "public_summary", "confidentiality_level", "reviewed_by", "review_notes"],
  "properties": {
    "evidence_id": {"type": "string", "pattern": "^EVD-[0-9]{3}$"},
    "evidence_type": {"enum": ["measurement", "simulation", "literature", "supplier_claim", "expert_judgment", "production_data", "field_data"]},
    "status": {"enum": ["draft", "reviewed", "rejected", "deprecated"]},
    "evidence_level": {"enum": ["unverified", "source_documented", "independently_measured", "customer_validated", "production_validated", "field_validated"]},
    "supports_claim_ids": {"type": "array", "items": {"type": "string"}},
    "contradicts_claim_ids": {"type": "array", "items": {"type": "string"}},
    "measurement_reference_ids": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
